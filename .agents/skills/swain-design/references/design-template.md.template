<!-- Jinja2 structural template — uses {{ variable }} placeholders. Read as a structural reference; no rendering pipeline needed. -->
---
title: "{{ title }}"
artifact: DESIGN-{{ number }}
status: {{ status | default("Draft") }}
author: {{ author }}
created: {{ created_date }}
last-updated: {{ last_updated_date }}
superseded-by: {{ superseded_by | default("") }}
linked-epics:
{%- for epic in linked_epics | default([]) %}
  - EPIC-{{ epic }}
{%- endfor %}
linked-stories:
{%- for story in linked_stories | default([]) %}
  - STORY-{{ story }}
{%- endfor %}
linked-specs:
{%- for spec in linked_specs | default([]) %}
  - SPEC-{{ spec }}
{%- endfor %}
linked-bugs:
{%- for bug in linked_bugs | default([]) %}
  - BUG-{{ bug }}
{%- endfor %}
depends-on:
{%- for dep in depends_on | default([]) %}
  - {{ dep }}
{%- endfor %}
---

# {{ title }}

