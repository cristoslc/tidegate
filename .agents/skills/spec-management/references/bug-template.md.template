<!-- Jinja2 structural template — uses {{ variable }} placeholders. Read as a structural reference; no rendering pipeline needed. -->
---
title: "{{ title }}"
artifact: BUG-{{ number }}
status: {{ status | default("Reported") }}
author: {{ author }}
created: {{ created_date }}
last-updated: {{ last_updated_date }}
severity: {{ severity | default("medium") }}
affected-artifacts:
{%- for ref in affected_artifacts | default([]) %}
  - {{ ref }}
{%- endfor %}
discovered-in: "{{ discovered_in | default("Describe where the bug was found") }}"
fix-ref: {{ fix_ref | default("") }}
depends-on:
{%- for dep in depends_on | default([]) %}
  - {{ dep }}
{%- endfor %}
execution-tracking: required
---

# {{ title }}

## Description

{{ description | default("Clear, concise description of the defect.") }}

## Reproduction Steps

{{ reproduction_steps | default("1. Step one\n2. Step two\n3. Observe the incorrect behavior") }}

## Expected Behavior

{{ expected_behavior | default("What should happen instead.") }}

## Actual Behavior

{{ actual_behavior | default("What happens now (the bug).") }}

## Impact

{{ impact | default("Who/what is affected and how severely.") }}

## Lifecycle

| Phase | Date | Commit | Notes |
|-------|------|--------|-------|
| {{ status | default("Reported") }} | {{ created_date }} | {{ commit_hash }} | Initial report |
